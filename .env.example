# --- Supabase (production backend) ---
# Leave these as YOUR_... placeholders to keep the app in DEMO MODE
# (an in-memory store seeded with sample vehicles). Fill them in to point
# the app at your real Supabase project.
NEXT_PUBLIC_SUPABASE_URL="YOUR_SUPABASE_URL"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Server-only. Used for admin writes (bypasses Row Level Security).
# NEVER expose this with NEXT_PUBLIC_ — it must stay on the server.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Storage bucket name for vehicle image uploads (created by supabase/schema.sql)
SUPABASE_STORAGE_BUCKET="vehicle-images"

# --- Admin auth (cookie-based, used to gate the /admin pages) ---
AUTH_SECRET="change-me-to-a-long-random-string-please"
ADMIN_EMAIL="admin@palmdriverentals.com"
ADMIN_PASSWORD="palmdrive123"
# Optional: set ADMIN_PASSWORD_HASH (bcrypt) to override ADMIN_PASSWORD
# ADMIN_PASSWORD_HASH=""
