# --- Firebase (production backend) ---
# Leave these as YOUR_... placeholders to keep the app in DEMO MODE
# (an in-memory store seeded with sample vehicles). Fill them in to point
# the app at your real Firebase project.
NEXT_PUBLIC_FIREBASE_API_KEY="YOUR_API_KEY"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
NEXT_PUBLIC_FIREBASE_APP_ID="YOUR_APP_ID"

# --- Admin auth (used by both demo and Firebase modes for the admin panel) ---
AUTH_SECRET="change-me-to-a-long-random-string-please"
ADMIN_EMAIL="admin@palmdriverentals.com"
ADMIN_PASSWORD="palmdrive123"
# Optional: set ADMIN_PASSWORD_HASH (bcrypt) to override ADMIN_PASSWORD
# ADMIN_PASSWORD_HASH=""
